+    - [0x1206420, asm,     fragments/78/fragment78]
+
+  - name: fragment78_relocs
+    type: code
+    bss_size: 0x0
+    start: 0x1219AF0
+    vram: 0x00000000
+    subsegments:
+    - [0x1219AF0, rodatabin, fragments/78/fragment78_reloc]
+
+  # Continuation of pokemon_models bin after the carved-out fragment78.
+  - name: pokemon_models_post
+    type: code
+    bss_size: 0x0
+    start: 0x1219E30
+    vram: 0x90F00000
+    ld_align_segment_start: 0x1219E30
