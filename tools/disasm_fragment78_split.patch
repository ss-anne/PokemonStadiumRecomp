 D_3008018 = 0x3008018;
 D_3007BE0 = 0x3007BE0;
 D_3007D48 = 0x3007D48;
+/* fragment78 false-positive symbol references — splat picked them up
+   from raw texture/displaylist data words like 0x80080080 that happen to
+   land near these vrams. The bytes are identical either way; declaring
+   them keeps the linker happy. */
+D_8007F730 = 0x8007F730;
+D_80081900 = 0x80081900;
